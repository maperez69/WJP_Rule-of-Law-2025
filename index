<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tablero WJP 2025 - México</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React y ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <!-- PropTypes (Requerido por Recharts UMD) -->
    <script src="https://unpkg.com/prop-types@15.8.1/prop-types.min.js"></script>
    <!-- Recharts -->
    <script src="https://unpkg.com/recharts@2.12.7/umd/Recharts.js"></script>
    <!-- Babel para procesar JSX en el navegador -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <style>
        body { background-color: #f9fafb; font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        // Extraer componentes de Recharts desde el objeto global
        const { 
            BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, 
            Cell 
        } = window.Recharts;

        // Iconos SVG definidos localmente para evitar errores de carga de librerías externas
        const Icons = {
            Landmark: () => (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="3" y1="21" x2="21" y2="21"/><line x1="9" y1="21" x2="9" y2="11"/><line x1="15" y1="21" x2="15" y2="11"/><path d="M19 11v-3l-7-4-7 4v3"/><path d="M5 11h14"/></svg>
            ),
            MapPin: () => (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            ),
            TrendingDown: () => (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>
            ),
            AlertTriangle: () => (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            ),
            Globe: () => (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            ),
            Scale: () => (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h18"/></svg>
            )
        };

        const WJP_DATA = {
            mexicoProfile: {
                score: 0.40,
                globalRank: 121,
                change: -2.8,
                factors: [
                    { subject: 'Límites al Poder', score: 0.41 },
                    { subject: 'Ausencia Corrupción', score: 0.26 },
                    { subject: 'Gobierno Abierto', score: 0.54 },
                    { subject: 'Derechos Fund.', score: 0.45 },
                    { subject: 'Orden y Seguridad', score: 0.50 },
                    { subject: 'Cumplimiento Reg.', score: 0.42 },
                    { subject: 'Justicia Civil', score: 0.36 },
                    { subject: 'Justicia Penal', score: 0.27 },
                ]
            },
            comparisonData: [
                { name: "Dinamarca", score: 0.90, fill: "#1e3a8a" },
                { name: "Uruguay", score: 0.72, fill: "#3b82f6" },
                { name: "Global", score: 0.55, fill: "#94a3b8" },
                { name: "México", score: 0.40, fill: "#047857" },
                { name: "Venezuela", score: 0.26, fill: "#ef4444" },
            ]
        };

        const StatCard = ({ title, value, subtext, icon: Icon, color }) => (
            <div className="bg-white p-5 rounded-xl shadow-sm border border-gray-100 flex items-start space-x-4">
                <div className={`p-3 rounded-lg ${color} text-white`}>
                    <Icon />
                </div>
                <div>
                    <p className="text-xs font-bold text-gray-400 uppercase tracking-wider">{title}</p>
                    <h3 className="text-2xl font-bold text-gray-900 leading-none mt-1">{value}</h3>
                    <p className="text-[10px] text-gray-400 mt-1">{subtext}</p>
                </div>
            </div>
        );

        const App = () => {
            const [activeTab, setActiveTab] = React.useState('mexico');

            return (
                <div className="max-w-7xl mx-auto p-4 md:p-8">
                    <header className="mb-8">
                        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                            <div>
                                <h1 className="text-2xl md:text-3xl font-extrabold text-blue-900 flex items-center gap-3">
                                    <Icons.Landmark />
                                    WJP Index 2025
                                </h1>
                                <p className="text-sm md:text-base text-gray-600 mt-1">Análisis del Estado de Derecho</p>
                            </div>
                            <div className="inline-flex items-center gap-2 self-start bg-green-100 text-green-800 px-4 py-2 rounded-full text-xs md:text-sm font-semibold border border-green-200">
                                <Icons.MapPin /> México: 0.40
                            </div>
                        </div>
                    </header>

                    <nav className="mb-6 flex space-x-2 overflow-x-auto pb-2 no-scrollbar">
                        <button 
                            onClick={() => setActiveTab('mexico')} 
                            className={`px-6 py-2 rounded-lg font-medium flex items-center gap-2 transition-all whitespace-nowrap text-sm md:text-base ${activeTab === 'mexico' ? 'bg-blue-600 text-white shadow-md' : 'bg-white text-gray-600 border'}`}
                        >
                            <Icons.MapPin /> 🇲🇽 México
                        </button>
                        <button 
                            onClick={() => setActiveTab('global')} 
                            className={`px-6 py-2 rounded-lg font-medium flex items-center gap-2 transition-all whitespace-nowrap text-sm md:text-base ${activeTab === 'global' ? 'bg-blue-600 text-white shadow-md' : 'bg-white text-gray-600 border'}`}
                        >
                            <Icons.Globe /> Global
                        </button>
                    </nav>

                    <main>
                        {activeTab === 'mexico' ? (
                            <div className="space-y-6">
                                <div className="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
                                    <StatCard title="Puntaje México" value="0.40" subtext="Escala 0 a 1" icon={Icons.MapPin} color="bg-green-700" />
                                    <StatCard title="Posición Global" value="#121" subtext="De 143 países" icon={Icons.TrendingDown} color="bg-red-600" />
                                    <StatCard title="Cambio Anual" value="-2.8%" subtext="Declive significativo" icon={Icons.AlertTriangle} color="bg-orange-600" />
                                </div>

                                <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                                    <div className="bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                                        <h3 className="text-lg font-bold mb-6">Comparativa Regional</h3>
                                        <div style={{ width: '100%', height: 300 }}>
                                            <ResponsiveContainer>
                                                <BarChart data={WJP_DATA.comparisonData} margin={{ bottom: 10 }}>
                                                    <CartesianGrid strokeDasharray="3 3" vertical={false} />
                                                    <XAxis dataKey="name" fontSize={10} interval={0} angle={-10} textAnchor="end" />
                                                    <YAxis domain={[0, 1]} fontSize={10} />
                                                    <Tooltip />
                                                    <Bar dataKey="score">
                                                        {WJP_DATA.comparisonData.map((entry, index) => (
                                                            <Cell key={`cell-${index}`} fill={entry.fill} />
                                                        ))}
                                                    </Bar>
                                                </BarChart>
                                            </ResponsiveContainer>
                                        </div>
                                    </div>

                                    <div className="bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                                        <h3 className="text-lg font-bold mb-4">Desempeño Específico</h3>
                                        <div className="space-y-4">
                                            <div className="p-4 bg-red-50 border border-red-100 rounded-lg">
                                                <p className="text-[10px] text-red-600 font-bold uppercase tracking-widest">Puesto Regional (LAC)</p>
                                                <p className="text-2xl font-bold text-red-900">27 / 32</p>
                                            </div>
                                            <div className="space-y-2">
                                                <div className="p-3 bg-green-50 border border-green-200 rounded text-xs md:text-sm text-green-800 font-bold">Líder en México: Gobierno Abierto (0.54)</div>
                                                <div className="p-3 bg-red-50 border border-red-200 rounded text-xs md:text-sm text-red-800 font-bold">Crítico: Ausencia de Corrupción (0.26)</div>
                                                <div className="p-3 bg-red-50 border border-red-200 rounded text-xs md:text-sm text-red-800 font-bold">Crítico: Justicia Penal (0.27)</div>
                                            </div>
                                            <p className="text-[10px] text-gray-400 italic mt-4 text-center">
                                                * Datos basados en el reporte WJP 2025
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ) : (
                            <div className="bg-white p-8 md:p-12 rounded-xl border text-center space-y-6 shadow-sm">
                                <Icons.Globe />
                                <h3 className="text-xl md:text-2xl font-bold">Resumen de la Recesión Global</h3>
                                <p className="text-gray-500 max-w-xl mx-auto text-sm md:text-base">
                                    El 68% de los países declinaron este año. La erosión de los límites al poder judicial y la reducción del espacio cívico son las tendencias más preocupantes a nivel mundial.
                                </p>
                                <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
                                    <div className="p-4 border rounded-lg bg-gray-50">
                                        <p className="text-2xl font-bold text-red-600">68%</p>
                                        <p className="text-[10px] text-gray-400 uppercase font-black">Declive Global</p>
                                    </div>
                                    <div className="p-4 border rounded-lg bg-gray-50">
                                        <p className="text-2xl font-bold text-red-600">70%</p>
                                        <p className="text-[10px] text-gray-400 uppercase font-black">Espacio Cívico ↓</p>
                                    </div>
                                    <div className="p-4 border rounded-lg bg-gray-50">
                                        <p className="text-2xl font-bold text-blue-600">0.90</p>
                                        <p className="text-[10px] text-gray-400 uppercase font-black">Top (Dinamarca)</p>
                                    </div>
                                    <div className="p-4 border rounded-lg bg-gray-50">
                                        <p className="text-2xl font-bold text-gray-600">0.55</p>
                                        <p className="text-[10px] text-gray-400 uppercase font-black">Promedio</p>
                                    </div>
                                </div>
                            </div>
                        )}
                    </main>

                    <footer className="mt-12 pt-8 border-t text-center text-gray-400 text-[10px] font-bold uppercase tracking-widest">
                        © 2025 World Justice Project | Reporte Final de México
                    </footer>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
